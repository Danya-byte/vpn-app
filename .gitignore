# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/
/dist/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Proxy core binaries + rule-sets — fetched via tool\fetch-cores.ps1, not committed (redistributable)
/core/**/*.exe
/core/**/*.dll
/core/**/*.srs
/core/**/*.sys
/core/**/*.bin
# EXCEPTION: tgcore.exe is the maintainer's OWN native-Telegram engine (source:
# github.com/Danya-byte/tg-core, GPL). It has no public release to pin/fetch, so —
# unlike the redistributable cores above — it is committed directly so CI/release
# builds include it. Rebuild from that repo's build.bat to refresh.
!/core/windows/tgcore.exe

# sing-box cache + any runtime db that lands in the tree (holds live state)
cache.db
*.db
